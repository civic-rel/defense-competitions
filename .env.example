# defense-aggregator v2 configuration.
#
# Copy to .env, fill in the keys you have, leave the rest as
# offline. The pipeline degrades gracefully — missing keys mean
# the corresponding adapter no-ops.

# -------- Logging --------
LOG_LEVEL=INFO

# -------- Search backend (used by sources/discover.py) --------
# Options:
#   offline  - return canned fixtures (default; for tests and demos)
#   brave    - Brave Search API; needs BRAVE_API_KEY
SEARCH_BACKEND=offline
BRAVE_API_KEY=

# Offline mode only — JSON fixture mapping queries to canned results.
OFFLINE_SEARCH_FIXTURE=tests/fixtures/search_results.json

# Offline mode only — JSON map of url -> local HTML file. Used by
# the discovery fetcher to replay scraped articles deterministically.
OFFLINE_FETCH_MAP=tests/fixtures/fetch_map.json

# -------- Crunchbase backend (used by enrich/crunchbase.py) --------
# Options:
#   offline  - JSON fixture (default)
#   live     - hits api.crunchbase.com; needs CRUNCHBASE_API_KEY
CRUNCHBASE_BACKEND=offline
CRUNCHBASE_API_KEY=
OFFLINE_CRUNCHBASE_FIXTURE=tests/fixtures/crunchbase_offline.json

# -------- FedRAMP backend (used by enrich/compliance.py) --------
# Options:
#   offline  - JSON fixture (default)
#   live     - hits marketplace.fedramp.gov; no API key needed
FEDRAMP_BACKEND=offline
OFFLINE_FEDRAMP_FIXTURE=tests/fixtures/fedramp_offline.json

# -------- SAM.gov (used by sources/samgov.py — carried from v1) --------
# Optional. Free key from https://api.sam.gov. Expires every 90 days.
SAM_API_KEY=

# -------- GitHub (used by sources/github.py) --------
# GITHUB_BACKEND options:
#   fixture  - read from tests/fixtures/github_repos.json (default;
#              no network)
#   api      - hit api.github.com (live)
# GITHUB_TOKEN: fine-grained PAT with `public_repo` read scope.
# Unauthenticated calls work but are rate-limited to 60/h.
# Get one at https://github.com/settings/tokens?type=beta
GITHUB_BACKEND=fixture
GITHUB_TOKEN=

# -------- dronedominance.mil (used by sources/dronedominance.py) --------
# DRONEDOMINANCE_BACKEND options:
#   fixture  - read tests/fixtures/dronedominance_vendors.html
#              (default; no .mil traffic)
#   live     - fetch https://dronedominance.mil/vendors.html
# Opt into live ONLY after clearing with the program office.
DRONEDOMINANCE_BACKEND=fixture
